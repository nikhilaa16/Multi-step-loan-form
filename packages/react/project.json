{
  "name": "react",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/react/src",
  "projectType": "library",
  "tags": [],
  "targets": {
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": [
        "{options.outputFile}"
      ],
      "options": {
        "lintFilePatterns": [
          "packages/react/**/*.{ts,tsx,js,jsx}"
        ]
      }
    },
    "prebuild": {
      "executor": "@nx/vite:build",
      "outputs": [
        "{options.outputPath}"
      ],
      "defaultConfiguration": "production",
      "options": {
        "outputPath": "dist/packages/react",
        "main": "index.js",
        "module": "index.js",
        "types": "index.d.ts",
        "assets": [
          "README.md",
          "package.json"
        ]
      },
      "configurations": {
        "development": {
          "mode": "development"
        },
        "production": {
          "mode": "production"
        }
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": [
        "{workspaceRoot}/coverage/{projectRoot}"
      ],
      "options": {
        "jestConfig": "packages/react/jest.config.ts"
      }
    },
    "build": {
      "dependsOn": [
        "prebuild"
      ],
      "command": "node -e \"const fs = require('fs'); const path = require('path'); fs.mkdirSync('dist/packages/react', { recursive: true }); fs.readdirSync('packages/react').filter(f => f.endsWith('.md')).forEach(f => fs.copyFileSync(path.join('packages/react', f), path.join('dist/packages/react', f)))\""
    }
  }
}